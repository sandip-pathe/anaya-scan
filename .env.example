# ─── GitHub App ───────────────────────────────────────────────
GITHUB_APP_ID=123456                          # Your GitHub App's numeric ID
GITHUB_PRIVATE_KEY_PATH=./private-key.pem     # Path to the PEM file downloaded from GitHub App settings
# GITHUB_PRIVATE_KEY_CONTENT=                 # Alternative: paste PEM content directly (for cloud deployments)
GITHUB_WEBHOOK_SECRET=your-webhook-secret     # The secret configured in your GitHub App webhook settings

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://anaya:anaya@localhost:5432/anaya  # AsyncPG connection string (auto-rewrites postgresql:// to +asyncpg)

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0            # Redis URL for Celery broker and token cache

# ─── Application ─────────────────────────────────────────────
APP_ENV=development                           # development | staging | production
APP_PORT=8000                                 # Port the API server listens on
APP_SECRET_KEY=change-me-to-a-random-string   # Secret key for internal signing (not GitHub-related)

# ─── Packs ───────────────────────────────────────────────────
PACKS_DIR=./anaya/packs                       # Directory containing rule pack definitions

# ─── LLM (Phase 2, optional) ─────────────────────────────────
# OPENAI_API_KEY=                             # Uncomment and set to enable LLM-powered code suggestions
